generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("dock_worker")
  badge     String?
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts       Shift[]
  cargoOps     CargoOperation[]
  signatures   Signature[]
  safetyChecks SafetyChecklist[]
}

model Shift {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  type      String    @default("day")
  status    String    @default("active")
  checkIn   DateTime  @default(now())
  checkOut  DateTime?
  location  String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model CargoOperation {
  id            String     @id @default(cuid())
  operationType String
  status        String     @default("pending")
  vesselName    String?
  voyageNumber  String?
  berthNumber   String?
  warehouseId   String?
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id])
  cargoType     String?
  reference     String?
  weight        Float?
  unitCount     Int?
  description   String?
  assignedTo    String?
  assignee      User?      @relation(fields: [assignedTo], references: [id])
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  items     CargoItem[]
  documents Document[]
}

model CargoItem {
  id              String          @id @default(cuid())
  cargoOpId       String
  cargoOperation  CargoOperation  @relation(fields: [cargoOpId], references: [id])
  itemType        String
  markOrNumber    String?
  description     String?
  quantity        Int             @default(1)
  weight          Float?
  condition       String          @default("good")
  damageNotes     String?
  storageLocation String?
  checked         Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  location  String?
  type      String   @default("general")
  capacity  Int?
  area      Float?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cargoOperations  CargoOperation[]
  storageLocations StorageLocation[]
}

model StorageLocation {
  id          String    @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  zone        String
  row         String?
  bay         String?
  level       String?
  occupied    Boolean   @default(false)
  cargoRef    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Document {
  id             String          @id @default(cuid())
  docType        String
  reference      String
  status         String          @default("draft")
  cargoOpId      String?
  cargoOperation CargoOperation? @relation(fields: [cargoOpId], references: [id])
  truckVisitId   String?
  truckVisit     TruckVisit?     @relation(fields: [truckVisitId], references: [id])
  content        String?
  photos         String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  signatures Signature[]
}

model Signature {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  signedBy   String
  signer     User     @relation(fields: [signedBy], references: [id])
  signerRole String?
  signedAt   DateTime @default(now())
}

model SafetyChecklist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  checkType String
  status    String   @default("pending")
  location  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items SafetyCheckItem[]
}

model SafetyCheckItem {
  id          String          @id @default(cuid())
  checklistId String
  checklist   SafetyChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  category    String
  question    String
  passed      Boolean?
  notes       String?
  orderIndex  Int             @default(0)
}

model TruckVisit {
  id               String   @id @default(cuid())
  driverName       String
  driverLicense    String?
  company          String?
  truckPlate       String
  trailerPlate     String?
  purpose          String
  status           String   @default("expected")
  dockNumber       String?
  expectedArrival  DateTime?
  arrivedAt        DateTime?
  dockAssignedAt   DateTime?
  completedAt      DateTime?
  cargoDescription String?
  blReference      String?
  bookingRef       String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  documents Document[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  category  String?
  linkId    String?
  createdAt DateTime @default(now())
}
